{
  "_comment": "BOT BUILDER — Agent Import Template v2.0 | Share this file with your users. Fill in YOUR values and remove all _comment fields before importing.",

  "agent_name": "My Agent Name",
  "agent_description": "A short description of what this agent does and who it serves.",
  "agent_role": "You are a [role]. Your job is to [primary task]. Always [key behavior].",
  "agent_instructions": "Optional extra instructions. For example: keep responses concise, always ask a follow-up question, etc.",
  "Examples": "Q: Sample question\nA: Sample answer\n\nQ: Another question\nA: Another answer",

  "llm": {
    "_comment": "provider must match exactly what is configured in your LLM Settings page",
    "provider": "OpenAI",
    "model": "GPT-4o",
    "temperature": 0.7,
    "max_tokens": 2048
  },

  "memory": {
    "_comment": "type options: short_term | long_term",
    "enabled": true,
    "type": "short_term"
  },

  "knowledge_base": {
    "_comment": "Provide KB IDs (numbers) or names (strings) from your Knowledge Base page. Leave both empty if not needed.",
    "ids": [],
    "names": []
  },

  "features": {
    "_comment": "Set any feature to true or false",
    "soundNatural": true,
    "thinkBack": false,
    "stayOnTopic": true,
    "explainClearly": true
  },

  "safe_ai_settings": {
    "_comment": "All fields optional. Remove sections you do not need.",
    "harmfulContent": true,
    "harmfulThreshold": 0.7,
    "maliciousInstructions": true,
    "maliciousThreshold": 0.5,
    "allowedTopics": false,
    "allowedKeywords": [],
    "blockedTopics": false,
    "blockedKeywords": [],
    "secrets": false,
    "secretKeywords": [],
    "keywordsEnabled": false,
    "keywordList": []
  },

  "_tools_comment": "REQUIRED — at least ONE tool must be included. Choose the tools your agent needs. Remove all tools you are NOT using. See each section below.",

  "tools": [

    {
      "_comment": "=== OPTION 1: HubSpot CRM (local / API token) ===",
      "tool_name": "hubspot",
      "tool_type": "local",
      "credentials": {
        "access_token": "YOUR_HUBSPOT_PRIVATE_APP_TOKEN",
        "refresh_token": "YOUR_HUBSPOT_REFRESH_TOKEN"
      }
    },

    {
