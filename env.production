# ===========================================
# Bot Builder Service - Production Environment
# ===========================================
# Rename this file to .env.production for use

# Base URL for generating asset URLs (avatars, backgrounds, etc.)
BASE_URL=https://api.jnanic.com

# OAuth Redirect URIs
OAUTH_REDIRECT_URI=https://jnanic.com/Admin/Tools
OAUTH_CALLBACK_URI=https://api.jnanic.com/oauth2callback

# External Service URLs
MCP_SERVICE_URL=https://mcp.jnanic.com
LANGGRAPH_SERVICE_URL=https://langgraph.jnanic.com
BOT_BUILDER_SERVICE_URL=https://api.jnanic.com

# Qdrant Vector Database
QDRANT_URL=https://qdrant.jnanic.com

# CORS Origins (comma-separated)
CORS_ORIGINS=https://jnanic.com,https://api.jnanic.com

# HubSpot OAuth
HUBSPOT_REDIRECT_URI=https://jnanic.com/Admin/Tools

